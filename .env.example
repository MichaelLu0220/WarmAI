WARMAI_API_KEY=replace-me
WARMAI_DATABASE_PATH=data/warmai.db
WARMAI_ADAPTER_KIND=mock
WARMAI_LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
WARMAI_LLAMA_CPP_MODEL=warmai-base-001
WARMAI_LOG_LEVEL=INFO
